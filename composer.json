{
    "name": "gianmds/cord",
    "description": "Framework de criação de UI e lógica de aplicação com máximo de facilidade para desenvolvimento.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Gianmds\\Cord\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Gian Mateus",
            "email": "gian.m.silver@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "blade-ui-kit/blade-icons": "^1.9",
        "illuminate/support": "^10.0 || ^11.0",
        "livewire/livewire": "^3.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "phpstan/phpstan": "^1.10",
        "laravel/pint": "^1.13"
    },
    "autoload-dev": {
        "psr-4": {
            "Vendor\\PackageName\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vendor\\PackageName\\PackageNameServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
