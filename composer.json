{
    "name": "cord/cord",
    "description": "Framework de criação de UI e lógica de aplicação com máximo de facilidade para desenvolvimento.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Cord\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Gian Mateus",
            "email": "gian.m.silver@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "anousss007/blatui": "^1.13",
        "gehrisandro/tailwind-merge-laravel": "^1.4",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/routing": "*",
        "illuminate/support": "^11.0 || ^12.0",
        "livewire/livewire": "^4.0",
        "mallardduck/blade-lucide-icons": "^1.26",
        "spatie/laravel-package-tools": "^1.16"
    },
        "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
        "pestphp/pest": "^2.0 || ^3.0 || ^4.0",
        "pestphp/pest-plugin-laravel": "^2.0 || ^3.0 || ^4.0",
        "phpstan/phpstan": "^1.10 || ^2.0",
        "laravel/pint": "^1.13"
    },
    "autoload-dev": {
        "psr-4": {
            "Cord\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cord\\Providers\\CordServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
    "artisan": "vendor/bin/testbench",
    "test": "vendor/bin/pest"
}
}
